-- View data from both tables
-- Objective: understand the structure, available columns, and identify initial inconsistencies

SELECT *
FROM us_household_income;

SELECT *
FROM us_household_income_statistics;

----------------------------------------------------------------------------
-- Rename column with corrupted characters (common encoding issue during data import)
-- Objective: standardize the column name to simplify queries and avoid future errors
ALTER TABLE us_household_income_statistics
RENAME COLUMN `ï»¿id` TO `id`
;

-- Count the number of records in each table
-- Objective: ensure consistency between tables and understand data volume
SELECT COUNT(id)
FROM us_household_income
;

SELECT COUNT(id)
FROM us_household_income_statistics
;


-- Check for duplicate IDs in the table
-- Objective: identify duplicate records that may distort analysis
-- 6 duplicates were found
SELECT id,
       COUNT(id)
FROM us_household_income
GROUP BY id
	HAVING COUNT(id) > 1
    ;


-- Use window function to identify exactly which records are duplicated
-- ROW_NUMBER assigns a sequence number to each occurrence within the same ID
SELECT *
FROM (
	SELECT row_id,
		   id,
		   ROW_NUMBER() OVER(PARTITION BY id ORDER BY id) AS row_num
	FROM us_household_income
	) AS duplicates
WHERE row_num > 1
;


-- Remove duplicate records while keeping only the first occurrence of each ID
-- Strategy: delete records where ROW_NUMBER > 1
DELETE FROM us_household_income
WHERE row_id IN (
	SELECT row_id
	FROM (
		SELECT row_id,
			   id,
			   ROW_NUMBER() OVER(PARTITION BY id ORDER BY id) AS row_num
		FROM us_household_income
		) AS duplicates
	WHERE row_num > 1
                 );


-- Check for duplicates in the statistics table
-- Result:
-- No duplicates were found in this table
SELECT id,
       COUNT(id)
FROM us_household_income_statistics
GROUP BY id
HAVING COUNT(id) > 1;


-- List distinct state names
-- Objective: identify inconsistencies in naming (e.g., lowercase or typos)
-- Georgia appears twice, one of them written as "georia"
-- Alabama appears twice, one of them written as "alabama"
SELECT DISTINCT State_Name
FROM us_household_income
GROUP BY State_Name
ORDER BY State_Name;

-- Fix typo in state name
UPDATE us_household_income
SET State_Name = 'Georgia'
WHERE State_Name = 'georia';

-- Standardize capitalization
UPDATE us_household_income
SET State_Name = 'Alabama'
WHERE State_Name = 'alabama';


-- Check state abbreviations
-- Objective: ensure standardization and absence of inconsistencies
-- No inconsistencies were found
SELECT DISTINCT State_ab
FROM us_household_income
ORDER BY State_ab;


-- Inspect data for a specific county
-- Objective: investigate potential inconsistencies in location data
SELECT *
FROM us_household_income
WHERE County = 'Autauga County'
ORDER BY 1;

-- Fix inconsistency between city and place
-- Objective: properly align geographic data
UPDATE us_household_income
SET Place = 'Autaugaville'
WHERE County = 'Autauga County'
AND City = 'Vinemont';


-- Count frequency of each region type
-- Objective: identify inconsistencies or duplicated categories
-- The type "Borough" appears twice, one of them written as "Boroughs"
SELECT Type,
       COUNT(Type)
FROM us_household_income
GROUP BY Type;

-- Fix naming inconsistency (plural vs singular)
UPDATE us_household_income
SET Type = 'Borough'
WHERE Type = 'Boroughs';


